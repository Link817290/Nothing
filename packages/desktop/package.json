{
  "name": "nothing-desktop",
  "version": "0.1.0",
  "description": "Nothing Mail — Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.nothingmail.desktop",
    "productName": "Nothing",
    "directories": {
      "output": "dist"
    },
    "icon": "icon_512.png",
    "files": ["main.js", "preload.js", "splash.html", "icon_512.png"],
    "win": {
      "target": ["nsis"],
      "icon": "icon.ico"
    },
    "mac": {
      "target": ["dmg"]
    },
    "linux": {
      "target": ["AppImage"]
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false
    }
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  }
}
