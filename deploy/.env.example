# Nothing — Deployment Configuration
# Copy to .env and edit before running: docker compose up -d

# ─── Domain ──────────────────────────────────────────────────
# Your domain (Caddy auto-HTTPS). Use "localhost" for local dev.
DOMAIN=nothing.example.com

# ─── Database ────────────────────────────────────────────────
DB_PASSWORD=change-me-please

# ─── Server ──────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-string
ENCRYPT_KEY=change-me-to-another-random-string

# ─── Mail (Stalwart) ────────────────────────────────────────
# Admin credentials for Stalwart management API
MAIL_ADMIN_USER=admin
MAIL_ADMIN_PASS=changeme

# Your server's public IP (used for DNS record generation)
SERVER_IP=

# Mail domain — users get username@MAIL_DOMAIN on registration
# Leave empty if only using third-party email (Gmail/QQ)
MAIL_DOMAIN=

# ─── Optional ────────────────────────────────────────────────
# OPEN_REGISTRATION=true
