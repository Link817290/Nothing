# Nothing — Deployment Configuration
# Copy this file to .env and edit before running docker compose up

# ─── Domain ──────────────────────────────────────────────────
# Your domain name (used by Caddy for auto HTTPS)
DOMAIN=nothing.example.com

# ─── Database ────────────────────────────────────────────────
DB_PASSWORD=change-me-please

# ─── Server ──────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-string
ENCRYPT_KEY=change-me-to-another-random-string

# ─── Mail (Stalwart) ────────────────────────────────────────
# Set to your domain for self-hosted mailboxes (@yourdomain.com)
# Leave empty if only using third-party email accounts (Gmail/QQ)
MAIL_DOMAIN=

# ─── Optional ────────────────────────────────────────────────
# Open registration (true/false). First user always becomes admin.
# OPEN_REGISTRATION=true
