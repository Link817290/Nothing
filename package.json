{
  "name": "nothing",
  "private": true,
  "scripts": {
    "dev:api": "pnpm --filter @nothing/api dev",
    "dev:web": "pnpm --filter @nothing/web dev",
    "dev:cli": "pnpm --filter nothing-cli dev",
    "build": "pnpm -r build",
    "build:nmp": "pnpm --filter @nothing/nmp build",
    "build:api": "pnpm --filter @nothing/api build",
    "build:web": "pnpm --filter @nothing/web build",
    "build:cli": "pnpm --filter nothing-cli build",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r exec rm -rf dist"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.32.1"
}
